Options -Indexes

# SPA-Routing: /wishes/* → index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Statische Dateien und API-Endpunkte direkt ausliefern
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^ - [L]

  # Alle anderen Pfade → index.html (SPA-Fallback)
  RewriteRule ^ index.html [L]
</IfModule>

# Sicherheits-Header
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Direktzugriff auf Datenspeicher-Verzeichnisse blockieren
RewriteEngine On
RewriteRule ^(wishdata|plandata)(/|$) - [F,L]
